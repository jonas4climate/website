---
import ProjectDetail from '../../../components/pages/ProjectDetail.astro';
import { entriesFor, slugOf } from '../../../i18n/utils';

export async function getStaticPaths() {
  const projects = (await entriesFor('projects', 'de')).sort(
    (a, b) => b.data.date.localeCompare(a.data.date) || a.data.order - b.data.order,
  );
  // prev/next stay within the same track (and locale — these are the German entries)
  return projects.map((project) => {
    const siblings = projects.filter((p) => p.data.track === project.data.track);
    const i = siblings.findIndex((p) => p.id === project.id);
    return {
      params: { slug: slugOf(project.id) },
      props: {
        project,
        prev: siblings[i - 1] ?? null,
        next: siblings[i + 1] ?? null,
      },
    };
  });
}

const { project, prev, next } = Astro.props;
---

<ProjectDetail lang="de" project={project} prev={prev} next={next} />
