---
// Embeds a video: a self-hosted file, or a YouTube / Vimeo clip.
//
//   <Video src="/media/thesis/demo.mp4" poster="/media/thesis/demo.jpg" caption="Control demo" />
//   <Video youtube="dQw4w9WgXcQ" caption="Talk recording" />
//   <Video vimeo="76979871" />
interface Props {
  /** Path/URL to a video file (mp4/webm). */
  src?: string;
  /** YouTube video id or full watch/share URL. */
  youtube?: string;
  /** Vimeo id or full URL. */
  vimeo?: string;
  poster?: string;
  caption?: string;
}
const { src, youtube, vimeo, poster, caption } = Astro.props;

// Accept either a bare id or a full URL for the embed providers.
function ytId(v: string) {
  const m = v.match(/(?:v=|youtu\.be\/|embed\/|shorts\/)([\w-]{11})/);
  return m ? m[1] : v;
}
function vimeoId(v: string) {
  const m = v.match(/(\d+)/);
  return m ? m[1] : v;
}

const embed = youtube
  ? `https://www.youtube-nocookie.com/embed/${ytId(youtube)}`
  : vimeo
    ? `https://player.vimeo.com/video/${vimeoId(vimeo)}`
    : null;
---

<figure class="media-video">
  {embed ? (
    <div class="media-video__frame">
      <iframe
        src={embed}
        title={caption ?? 'Embedded video'}
        loading="lazy"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    </div>
  ) : src ? (
    <video controls preload="metadata" poster={poster} playsinline>
      <source src={src} />
      Your browser can’t play this video. <a href={src}>Download it</a> instead.
    </video>
  ) : null}
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .media-video {
    margin-block: var(--space-l);
  }
  .media-video__frame {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--surface);
  }
  .media-video__frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .media-video video {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    background: #000;
  }
  .media-video figcaption {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--faint);
    margin-top: 0.5rem;
  }
</style>
